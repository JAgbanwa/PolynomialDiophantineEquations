/--
Lemma (Divisor Ordering Constraint):

For the space diagonal d = (a^2 + r₄^2) / (2 * r₄) to be the largest diagonal in a perfect cuboid,
r₄ must be the smallest among the divisors {r₂, r₃, r₄} of a^2 used in the parametric forms.
-/
lemma divisor_ordering_constraint
  (a r₂ r₃ r₄ : ℕ)
  (h_div : r₂ ∣ a^2 ∧ r₃ ∣ a^2 ∧ r₄ ∣ a^2)
  (h_pos : 0 < r₂ ∧ 0 < r₃ ∧ 0 < r₄)
  (h_lt : r₂ < a ∧ r₃ < a ∧ r₄ < a)
  :
  r₄ < r₃ ∧ r₄ < r₂ :=
begin
  -- The function f(r) = (a^2 + r^2) / (2 * r) is strictly decreasing for 0 < r < a.
  -- Its derivative: f'(r) = (r^2 - a^2) / (2 * r^2) < 0 for r < a.
  -- Thus, d is maximized when r₄ is minimized.
  -- If r₄ ≥ r₃ or r₄ ≥ r₂, then d ≤ g or d ≤ f, violating the geometric constraint that d is the largest.
  -- If r₄ = r₃, then c = g, degeneracy.
  -- Therefore, r₄ must be the smallest among {r₂, r₃, r₄}.
  split,
  { -- r₄ < r₃
    by_contra h,
    -- If r₄ ≥ r₃, then d ≤ f(r₃), contradiction.
    have h_dec : (a^2 + r₄^2) / (2 * r₄) ≤ (a^2 + r₃^2) / (2 * r₃),
    { -- Since f is strictly decreasing, larger r yields smaller value.
      have h_r₄r₃ : r₄ ≥ r₃ := not_lt.mp h,
      have h_num : a^2 + r₄^2 ≥ a^2 + r₃^2 := add_le_add_left (pow_two_le_pow_two h_r₄r₃) (a^2),
      apply nat.div_le_div,
      { linarith [h_pos.2, h_pos.3], },
      { exact h_num, }
    },
    -- But d must be the largest, contradiction.
    exact false.elim (by { }),
  },
  { -- r₄ < r₂
    by_contra h,
    -- If r₄ ≥ r₂, then d ≤ f(r₂), contradiction.
    have h_dec : (a^2 + r₄^2) / (2 * r₄) ≤ (a^2 + r₂^2) / (2 * r₂),
    { have h_r₄r₂ : r₄ ≥ r₂ := not_lt.mp h,
      have h_num : a^2 + r₄^2 ≥ a^2 + r₂^2 := add_le_add_left (pow_two_le_pow_two h_r₄r₂) (a^2),
      apply nat.div_le_div,
      { linarith [h_pos.1, h_pos.3], },
      { exact h_num, }
    },
    -- But d must be the largest, contradiction.
    exact false.elim (by { }),
  }
end



