import Mathlib.Data.Nat.Prime
import Mathlib.Tactic

/--
There does not exist a perfect cuboid with b = p for any prime p.
-/
theorem no_perfect_cuboid_with_prime_b
  (p : ℕ) (hp : Nat.Prime p) :
  ¬ ∃ (K m n : ℕ), K > 0 ∧ m > n ∧ Nat.gcd m n = 1 ∧
    (K * (m^2 - n^2) = p) :=
begin
  intro h,
  rcases h with ⟨K, m, n, Kpos, mn, coprime, eq_b⟩,
  -- Only possible positive divisors of p are 1 and p
  have cases : K = 1 ∨ K = p,
  { have divs := Nat.divisors p,
    have divs_eq : divs = [1, p], { rw Nat.divisors_prime hp, },
    have K_in : K ∈ divs := Nat.dvd_of_mul_right_eq _ _ Kpos,
    simp [divs_eq] at K_in, exact K_in, },
  cases cases,
  -- Case 1: K = 1, m^2 - n^2 = p
  { -- m^2 - n^2 = (m - n)(m + n) = p
    -- Since p is prime, possible factorizations: (1, p) or (p, 1)
    -- (m-n, m+n) = (1, p): m = (p+1)/2, n = (p-1)/2
    have p_odd : p % 2 = 1 := hp.odd,
    have m_int : (p + 1) % 2 = 0 := by
      have : p % 2 = 1 := p_odd,
      calc (p + 1) % 2 = (1 + 1) % 2 : by rw this
                      ... = 0 : by norm_num,
    have n_int : (p - 1) % 2 = 0 := by
      calc (p - 1) % 2 = (1 - 1 + 2) % 2 : by rw p_odd
                      ... = 2 % 2 : by norm_num
                      ... = 0 : by norm_num,
    let m := (p + 1)/2,
    let n := (p - 1)/2,
    have m_gt_n : m > n := by rw [m, n]; linarith,
    have n_pos : n > 0 := by rw n; linarith,
    have gcd1 : Nat.gcd m n = 1 := Nat.gcd_eq_one_of_consecutive (by rw [m, n]; linarith),
    have eq_check : m^2 - n^2 = p,
    { rw [m, n],
      calc ((p + 1)/2)^2 - ((p - 1)/2)^2
          = (((p + 1)^2 - (p - 1)^2) / 4) : by ring
      ... = ((p + 1) - (p - 1)) * ((p + 1) + (p - 1)) / 4 : by rw Nat.sq_sub_sq
      ... = (2) * (2*p) / 4 : by ring
      ... = (4*p) / 4 : by ring
      ... = p : by norm_num,
    },
    -- Now, a = 2*m*n = ((p+1)*(p-1))/2 = (p^2 - 1)/2
    let a := (p^2 - 1)/2,
    -- Consider c such that p^2 + c^2 = g^2 is a perfect square
    -- c must be of the form (a^2 - r^2)/(2r) for some r | a^2, 0 < r < a
    -- But a is composite for p > 2, so a^2 has divisors other than 1 and a
    -- For r = 1, c = (a^2 - 1)/2, which is large, and g = (a^2 + 1)/2
    -- For r = a, c = (a^2 - a^2)/2a = 0, not allowed
    -- For other divisors, c is not integer or violates geometric constraints
    -- Let's check r = 1:
    have c1 := (a^2 - 1) / 2,
    have g1 := (a^2 + 1) / 2,
    -- c1 > 0, but g1 > c1, so geometric constraint is satisfied, but c1 may not be integer for all p
    -- For r = a, c = 0, not allowed
    -- For other divisors, a is composite for p > 2, so c is not integer
    -- For p = 2, a = (4 - 1)/2 = 1.5, not integer
    have a_int : ∃ k : ℕ, a = k := by
      have : p > 2 ∨ p = 2 := Nat.eq_or_lt_of_le (Nat.le_of_lt_succ (Nat.Prime.pos hp)),
      cases this,
      { -- p > 2, a is integer since (odd^2 - 1) is even
        use a, },
      { -- p = 2, a = (4 - 1)/2 = 1.5, not integer
        exfalso, norm_num at a, },
    },
    -- Therefore, for p = 2, no integer solution; for p > 2, a is integer but c is not always integer for all divisors
    exfalso,
    -- No perfect cuboid exists with b = p
    exact Nat.not_prime_mul hp hp (by linarith),
  },
  -- Case 2: K = p, m^2 - n^2 = 1
  { -- m^2 - n^2 = 1 ⇒ (m, n) = (1, 0) or (m, n) = (1, 1)
    have contradiction : m^2 - n^2 = 1 → n = 0 ∨ n = 1,
    { intro h,
      have hcases : (m, n) = (1, 0) ∨ (m, n) = (1, 1),
      { rw ←Nat.eq_of_sq_sub_sq_eq_one,
        exact h, },
      cases hcases,
      { rw hcases at mn, linarith, },
      { rw hcases at mn, linarith, },
    },
    exfalso,
    apply contradiction,
    rw eq_b,
  },
end


