import Mathlib.Data.Nat.Prime

/--
Lemma (Product of Two Primes Constraint):

Let a = p * q, where p and q are distinct primes. Then the parametric forms of the other sides lead to a contradiction, making such a cuboid impossible.
-/
lemma no_perfect_cuboid_biprime_a
  (p q : ℕ) (hp : Nat.Prime p) (hq : Nat.Prime q) (hneq : p ≠ q) :
  ¬ ∃ (b c g : ℕ),
    ∃ (r₂ r₃ r₄ : ℕ),
      r₂ ∣ (p * q)^2 ∧ r₃ ∣ (p * q)^2 ∧ r₄ ∣ (p * q)^2 ∧
      0 < r₄ ∧ r₄ < r₃ ∧ r₃ < r₂ ∧ r₂ < p * q ∧
      b = ((p * q)^2 - r₂^2) / (2 * r₂) ∧
      c = ((p * q)^2 - r₃^2) / (2 * r₃) ∧
      g = ((p * q)^2 - r₄^2) / (2 * r₄) ∧
      b^2 + c^2 = g^2 :=
begin
  rintro ⟨b, c, g, r₂, r₃, r₄, h₂, h₃, h₄, h₄pos, h₄r₃, h₃r₂, h₂lt, hb, hc, hg, h_eq⟩,
  let a := p * q,
  -- Expand b^2 + c^2
  have b_sq : b^2 = ((a^2 - r₂^2)^2) / (4 * r₂^2), by rw hb,
  have c_sq : c^2 = ((a^2 - r₃^2)^2) / (4 * r₃^2), by rw hc,
  -- Expand g^2
  have g_sq : g^2 = ((a^2 - r₄^2)^2) / (4 * r₄^2), by rw hg,
  -- Combine b^2 + c^2
  have lhs : ℚ :=
    ((a^4 - 2 * a^2 * r₂^2 + r₂^4) * r₃^2 +
     (a^4 - 2 * a^2 * r₃^2 + r₃^4) * r₂^2) /
    (4 * r₂^2 * r₃^2),
  -- Expand numerator:
  -- = a^4 * (r₂^2 + r₃^2) - 4 * a^2 * r₂^2 * r₃^2 + r₂^2 * r₃^2 * (r₂^2 + r₃^2)
  -- = ((a^4 + r₂^2 * r₃^2) * (r₂^2 + r₃^2) - 4 * a^2 * r₂^2 * r₃^2) / (4 * r₂^2 * r₃^2)
  -- Expand g^2:
  have rhs : ℚ :=
    (a^4 - 2 * a^2 * r₄^2 + r₄^4) / (4 * r₄^2),
  -- Cross-multiply to compare:
  -- lhs * r₄^2 = rhs * r₂^2 * r₃^2
  -- This yields:
  -- (a^4 + r₂^2 * r₃^2) * (r₂^2 + r₃^2) * r₄^2 - 4 * a^2 * r₂^2 * r₃^2 * r₄^2
  -- ≠ (a^4 - 2 * a^2 * r₄^2 + r₄^4) * r₂^2 * r₃^2
  -- Rearranged:
  -- a^4 * (r₃^2 * r₄^2 + r₂^2 * r₄^2 - r₂^2 * r₃^2)
  -- - 2 * a^2 * r₂^2 * r₃^2 * r₄^2
  -- + r₂^2 * r₃^2 * r₄^2 * (r₂^2 + r₃^2 - r₄^2) ≠ 0
  -- Now, under the ordering 0 < r₄ < r₃ < r₂ < a:
  -- First term is negative, second term is negative, third term is positive.
  -- The sum cannot be zero.
  have contradiction :
    a^4 * (r₃^2 * r₄^2 + r₂^2 * r₄^2 - r₂^2 * r₃^2)
    - 2 * a^2 * r₂^2 * r₃^2 * r₄^2
    + r₂^2 * r₃^2 * r₄^2 * (r₂^2 + r₃^2 - r₄^2) ≠ 0,
  {
    -- By sign analysis:
    -- First term: r₃^2 * r₄^2 + r₂^2 * r₄^2 - r₂^2 * r₃^2 < 0
