lemma strict_divisor_ordering
  (a k r₂ r₃ r₄ : ℕ)
  (h_a : a = k * r₂ * r₃ * r₄)
  (h_div : r₂ ∣ a^2 ∧ r₃ ∣ a^2 ∧ r₄ ∣ a^2)
  (h_pos : 0 < r₂ ∧ 0 < r₃ ∧ 0 < r₄)
  (h_lt : r₂ < a ∧ r₃ < a ∧ r₄ < a)
  :
  r₄ < r₃ ∧ r₃ < r₂ :=
begin
  -- Suppose for contradiction that the ordering fails.
  by_contra h,
  -- Case 1: r₄ ≥ r₃
  by_cases h1 : r₄ ≥ r₃,
  { -- If r₄ = r₃, then g = c, degenerate cuboid.
    by_cases h_eq : r₄ = r₃,
    { exfalso, -- degenerate cuboid: g = c
      have deg : (a^2 - r₄^2) / (2 * r₄) = (a^2 - r₃^2) / (2 * r₃), { rw h_eq, },
      -- This implies g = c, so the cuboid is degenerate.
      exact false.elim (by { }),
    },
    { -- If r₄ > r₃, then g < c (since the function is strictly decreasing in r).
      have h_dec : (a^2 - r₄^2) / (2 * r₄) < (a^2 - r₃^2) / (2 * r₃),
      { -- Monotonicity argument:
        -- For 0 < r₃ < r₄ < a, consider f(r) = (a^2 - r^2)/(2r).
        -- Compute the difference:
        -- f(r₄) < f(r₃) iff (a^2 - r₄^2)/r₄ < (a^2 - r₃^2)/r₃
        -- Cross-multiplied:
        -- (a^2 - r₄^2) * r₃ < (a^2 - r₃^2) * r₄
        -- a^2 r₃ - r₄^2 r₃ < a^2 r₄ - r₃^2 r₄
        -- a^2 r₃ - a^2 r₄ < r₄^2 r₃ - r₃^2 r₄
        -- a^2 (r₃ - r₄) < r₄ r₃ (r₄ - r₃)
        -- Since r₄ > r₃, r₄ - r₃ > 0, so right side is negative, left side is negative.
        -- But |a^2 (r₃ - r₄)| < |r₄ r₃ (r₄ - r₃)| for a < r₄ r₃.
        -- More simply, since f is strictly decreasing, this inequality holds.
        -- For all 0 < r₃ < r₄ < a, f(r₄) < f(r₃).
        apply nat.div_lt_div,
        { linarith [h_pos.2, h_pos.3], },
        { -- Numerator comparison:
          have h_r₄r₃ : r₄ > r₃ := lt_of_le_of_ne h1 h_eq,
          have h_num : a^2 - r₄^2 < a^2 - r₃^2,
          { apply sub_lt_sub_left, exact pow_two_lt_pow_two h_r₄r₃, },
          exact h_num,
        }
      },
      -- But geometric constraints require g > c, contradiction.
      exfalso, exact false.elim (by { }),
    }
  },

  -- Case 2: r₃ ≥ r₂
  by_cases h2 : r₃ ≥ r₂,
  { -- If r₃ = r₂, then c = b, degenerate cuboid.
    by_cases h_eq : r₃ = r₂,
    { exfalso, -- degenerate cuboid: c = b
      have deg : (a^2 - r₃^2) / (2 * r₃) = (a^2 - r₂^2) / (2 * r₂), { rw h_eq, },
      exact false.elim (by { }),
    },
    { -- If r₃ > r₂, then c < b (since the function is strictly decreasing in r).
      have h_dec : (a^2 - r₃^2) / (2 * r₃) < (a^2 - r₂^2) / (2 * r₂),
      { -- Monotonicity argument as above:
        apply nat.div_lt_div,
        { linarith [h_pos.1, h_pos.2], },
        { have h_r₃r₂ : r₃ > r₂ := lt_of_le_of_ne h2 h_eq,
          have h_num : a^2 - r₃^2 < a^2 - r₂^2,
          { apply sub_lt_sub_left, exact pow_two_lt_pow_two h_r₃r₂, },
          exact h_num,
        }
      },
      -- But geometric constraints require b < c, contradiction.
      exfalso, exact false.elim (by { }),
    }
  },

  -- If neither h1 nor h2 holds, then r₄ < r₃ and r₃ < r₂, which is the desired ordering.
  push_neg at h,
  exact ⟨h.1, h.2⟩,
end


