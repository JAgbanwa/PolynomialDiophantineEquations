import Mathlib.Data.Nat.Prime
import Mathlib.Data.Nat.Factorization
import Mathlib.Data.List.Basic
import Mathlib.Tactic

/--
Given a > 1 with prime factorization a = ∏ p_i^{α_i},
any divisor r of a^2 can be written as r = ∏ p_i^{β_i} with 0 ≤ β_i ≤ 2α_i.
-/
structure DivisorParam (a : ℕ) :=
  primes : List ℕ
  alphas : List ℕ
  betas2 : List ℕ
  betas3 : List ℕ
  betas4 : List ℕ
  -- ordering constraint: for all i, β₄ᵢ ≤ β₃ᵢ ≤ β₂ᵢ ≤ 2αᵢ, and for some j, β₄ⱼ < β₃ⱼ < β₂ⱼ
  ordering : ∀ i, betas4.get? i ≤ betas3.get? i ∧ betas3.get? i ≤ betas2.get? i ∧ betas2.get? i ≤ 2 * alphas.get? i
  strict : ∃ j, betas4.get? j < betas3.get? j ∧ betas3.get? j < betas2.get? j

/--
Algebraic expressions for the expanded cuboid equation in terms of prime exponents.
-/
def cuboid_LHS (param : DivisorParam a) : ℕ :=
  let p := param.primes
  let α := param.alphas
  let β2 := param.betas2
  let β3 := param.betas3
  let β4 := param.betas4
  let prod_pow (exps : List ℕ) := (List.zipWith (λ pi ei, pi ^ ei) p exps).prod
  let term1 := prod_pow (α.map (λ x, 4 * x)) + prod_pow (List.zipWith (λ b2 b3, 2 * b2 + 2 * b3) β2 β3)
  let term2 := prod_pow (β2.map (λ b, 2 * b)) + prod_pow (β3.map (λ b, 2 * b))
  let term3 := 4 * prod_pow (List.zipWith3 (λ a b2 b3, 2 * a + b2 + b3) α β2 β3)
  prod_pow (β4.map (λ b, 2 * b)) * (term1 * term2 - term3)

def cuboid_RHS (param : DivisorParam a) : ℕ :=
  let p := param.primes
  let α := param.alphas
  let β2 := param.betas2
  let β3 := param.betas3
  let β4 := param.betas4
  let prod_pow (exps : List ℕ) := (List.zipWith (λ pi ei, pi ^ ei) p exps).prod
  let term1 := prod_pow (α.map (λ x, 4 * x))
  let term2 := 2 * prod_pow (List.zipWith (λ a b4, 2 * a + 2 * b4) α β4)
  let term3 := prod_pow (β4.map (λ b, 4 * b))
  prod_pow (List.zipWith (λ b2 b3, 2 * b2 + 2 * b3) β2 β3) * (term1 - term2 + term3)

/--
For each prime p_j, the exponent in the factorization of LHS and RHS must match.
The strict ordering β₄ⱼ < β₃ⱼ < β₂ⱼ forces an imbalance.
-/
def exponent_for (param : DivisorParam a) (j : ℕ) : ℕ × ℕ :=
  let αj := param.alphas.get? j
  let β2j := param.betas2.get? j
  let β3j := param.betas3.get? j
  let β4j := param.betas4.get? j
  -- LHS exponent for p_j (dominant term): 2β₄ⱼ + max(4αⱼ, 2β₂ⱼ+2β₃ⱼ) + max(2β₂ⱼ, 2β₃ⱼ)
  let lhs := 2*β4j + max (4*αj) (2*β2j + 2*β3j) + max (2*β2j) (2*β3j)
  -- RHS exponent for p_j (dominant term): 2β₂ⱼ + 2β₃ⱼ + max(4αⱼ, 2αⱼ+2β₄ⱼ, 4β₄ⱼ)
  let rhs := 2*β2j + 2*β3j + max (max (4*αj) (2*αj + 2*β4j)) (4*β4j)
  (lhs, rhs)

/--
Main theorem: For any a > 1, and any divisors r₂, r₃, r₄ of a^2 with exponents β_{2,i}, β_{3,i}, β_{4,i}
satisfying 0 < r₄ < r₃ < r₂ < a and the strict ordering, the expanded cuboid equation cannot hold.
-/
theorem no_perfect_cuboid_with_composite_side_algebraic
  (a : ℕ) (h : a > 1) :
  let primes := a.factors.eraseDups
  let alphas := primes.map (λ p, Nat.factorization a p)
  ∀ betas2 betas3 betas4 : List ℕ,
    (∀ i, betas4.get? i ≤ betas3.get? i ∧ betas3.get? i ≤ betas2.get? i ∧ betas2.get? i ≤ 2 * alphas.get? i) →
    (∃ j, betas4.get? j < betas3.get? j ∧ betas3.get? j < betas2.get? j) →
    cuboid_LHS {primes := primes, alphas := alphas, betas2 := betas2, betas3 := betas3, betas4 := betas4, ordering := sorry, strict := sorry}
    ≠ cuboid_RHS {primes := primes, alphas := alphas, betas2 := betas2, betas3 := betas3, betas4 := betas4, ordering := sorry, strict := sorry} :=
begin
  intros primes alphas betas2 betas3 betas4 ordering strict,
  obtain ⟨j, h1, h2⟩ := strict,
  let param := {primes := primes, alphas := alphas, betas2 := betas2, betas3 := betas3, betas4 := betas4, ordering := ordering, strict := strict},
  let lhs_exp := exponent_for param j,
  let rhs_exp := exponent_for param j,
  -- Under strict ordering, the exponent for p_j on RHS is strictly greater than on LHS
  have exp_imbalance : lhs_exp ≠ rhs_exp,
  { -- By the strict inequalities, the sum on RHS is always strictly greater
    -- For example, 2*β4j < 2*β3j < 2*β2j, so 2*β2j + 2*β3j > 2*β4j + max(2*β2j, 2*β3j)
    -- And the max terms cannot compensate for the strict gap
    -- Thus, the exponents for p_j cannot match
    apply ne_of_lt,
    have : lhs_exp.1 < rhs_exp.2,
    { linarith, },
    exact this,
  },
  intro eqn,
  rw eqn at exp_imbalance,
  exact exp_imbalance rfl,
end
