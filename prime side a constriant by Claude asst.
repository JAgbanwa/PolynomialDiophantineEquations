-- Definition of a perfect cuboid
structure PerfectCuboid where
  a b c d e f g : ℕ
  pos_a : 0 < a
  pos_b : 0 < b  
  pos_c : 0 < c
  pos_d : 0 < d
  pos_e : 0 < e
  pos_f : 0 < f
  pos_g : 0 < g
  eq1 : a^2 + b^2 + c^2 = d^2  -- space diagonal
  eq2 : a^2 + b^2 = e^2        -- face diagonal ab
  eq3 : a^2 + c^2 = f^2        -- face diagonal ac  
  eq4 : b^2 + c^2 = g^2        -- face diagonal bc

-- Key lemma: Divisors of p^2 for prime p
lemma divisors_of_prime_squared (p : ℕ) (hp : Nat.Prime p) :
  ∀ d : ℕ, d ∣ p^2 ↔ d ∈ ({1, p, p^2} : Set ℕ) := by
  intro d
  constructor
  · intro h_div
    have h := Nat.dvd_prime_pow hp 2 d h_div
    cases h with
    | inl h1 => exact Set.mem_insert _ _ (Set.mem_singleton_iff.mpr h1)
    | inr h_rest =>
      cases h_rest with
      | inl h_p => exact Set.mem_insert_of_mem _ (Set.mem_insert _ _ (Set.mem_singleton_iff.mpr h_p))
      | inr h_p2 => exact Set.mem_insert_of_mem _ (Set.mem_insert_of_mem _ (Set.mem_singleton_iff.mpr h_p2))
  · intro h_mem
    cases' Set.mem_insert_iff.mp h_mem with h1 h_rest
    · rw [h1]; exact Nat.one_dvd _
    · cases' Set.mem_insert_iff.mp h_rest with h_p h_p2
      · rw [h_p]; exact Nat.dvd_pow_self _ (by norm_num)
      · rw [Set.mem_singleton_iff] at h_p2; rw [h_p2]

-- Parametric forms derived from face diagonal equations
def param_b (a r : ℕ) : ℚ := (a^2 - r^2 : ℚ) / (2 * r)
def param_c (a s : ℕ) : ℚ := (a^2 - s^2 : ℚ) / (2 * s)  
def param_g (a t : ℕ) : ℚ := (a^2 - t^2 : ℚ) / (2 * t)

-- Core lemma: If a^2 + b^2 = e^2, then b has the parametric form
lemma face_diagonal_parametrization (a b e : ℕ) (ha : 0 < a) (hb : 0 < b) (he : 0 < e) :
  a^2 + b^2 = e^2 → ∃ r : ℕ, r ∣ a^2 ∧ 0 < r ∧ r < a ∧ (b : ℚ) = param_b a r := by
  intro h_eq
  -- From e^2 - b^2 = a^2, we get (e-b)(e+b) = a^2
  have factorization : (e - b) * (e + b) = a^2 := by
    rw [←Nat.pow_two, ←Nat.pow_two, ←Nat.pow_two] at h_eq
    have h1 : e^2 = a^2 + b^2 := h_eq.symm
    rw [Nat.pow_two, Nat.pow_two, Nat.pow_two] at h1
    have h2 : e * e = a * a + b * b := h1
    have h3 : e * e - b * b = a * a := by linarith
    rw [←Nat.mul_sub_left_distrib] at h3
    exact h3.symm

  -- Since e > b (as e^2 > b^2), both factors are positive
  have e_gt_b : b < e := by
    by_contra h
    push_neg at h
    have : e^2 ≤ b^2 := Nat.pow_le_pow_right (by norm_num) h
    rw [h_eq] at this
    linarith [Nat.zero_lt_pow_iff.mpr ⟨by norm_num, ha⟩]

  -- Let r = e - b, then e + b = a^2/r  
  let r := e - b
  have r_pos : 0 < r := Nat.sub_pos_of_lt e_gt_b
  have r_div_a2 : r ∣ a^2 := by
    use (e + b)
    exact factorization

  -- Show r < a
  have r_lt_a : r < a := by
    -- From (e-b)(e+b) = a^2 and e > b ≥ 1, we have:
    -- r(e+b) = a^2, so r ≤ a^2/(e+b) < a^2/2 ≤ a for a ≥ 2
    -- For a = 1: impossible since a^2 + b^2 = e^2 with positive b,e
    by_cases ha_eq_1 : a = 1
    · -- Case a = 1: leads to contradiction
      rw [ha_eq_1] at h_eq
      simp at h_eq
      have : 1 + b^2 = e^2 := h_eq
      have b_ge_1 : 1 ≤ b := hb
      have : 2 ≤ e^2 := by linarith [Nat.one_le_pow _ _ b_ge_1]
      have e_ge_2 : 2 ≤ e := by
        by_contra h
        push_neg at h
        interval_cases e
        · exact Nat.not_lt_zero _ he
        · simp at this
      -- If b ≥ 1 and e ≥ 2, then e + b ≥ 3
      -- But r = e - b could be 1, and r(e+b) = 1 ≠ 1 = a^2
      -- More carefully: 1 + b^2 = e^2, so e^2 - b^2 = 1
      -- Thus (e-b)(e+b) = 1, so e-b = 1 and e+b = 1
      -- But e+b ≥ 2, contradiction
      have sum_ge_2 : 2 ≤ e + b := by linarith [he, hb]
      have from_factorization : (e - b) * (e + b) = 1 := by rw [ha_eq_1] at factorization; exact factorization
      have factors_are_1 : e - b = 1 ∧ e + b = 1 := by
        have pos_factors : 0 < e - b ∧ 0 < e + b := ⟨Nat.sub_pos_of_lt e_gt_b, by linarith [he, hb]⟩
        exact Nat.eq_one_of_mul_eq_one_right from_factorization pos_factors.1 pos_factors.2
      linarith [factors_are_1.2, sum_ge_2]
    · -- Case a ≥ 2  
      have a_ge_2 : 2 ≤ a := Nat.two_le_iff.mpr ⟨ne_of_gt ha, ha_eq_1⟩
      -- From r(e+b) = a^2 and e+b ≥ b+1 ≥ 2, we get r ≤ a^2/2
      -- For a ≥ 2, a^2/2 ≥ 2, and we need to show r < a
      have e_plus_b_ge_2 : 2 ≤ e + b := by linarith [he, hb]
      have : r * (e + b) = a^2 := factorization
      have r_bound : r ≤ a^2 / 2 := by
        have : r * (e + b) ≤ r * (a^2) := by
          -- This requires showing e + b ≤ a^2, which needs more work
          -- Let's use a different approach
          sorry
        sorry
      sorry -- Complete the bound r < a

  -- Show the parametric form
  have param_form : (b : ℚ) = param_b a r := by
    unfold param_b
    -- We have r = e - b and r(e + b) = a^2
    -- So e + b = a^2/r and e - b = r  
    -- Adding: 2e = r + a^2/r, so e = (r^2 + a^2)/(2r)
    -- Subtracting: 2b = a^2/r - r = (a^2 - r^2)/(r), so b = (a^2 - r^2)/(2r)
    have e_form : (e : ℚ) = (r^2 + a^2 : ℚ) / (2 * r) := by
      field_simp
      -- From r(e + b) = a^2 and r = e - b:
      -- r·e + r·b = a^2 and r = e - b
      -- So r·e + r·b = a^2 and e = r + b  
      -- Thus r(r + b) + r·b = a^2
      -- r^2 + 2rb = a^2
      -- So e = r + b and r^2 + 2rb = a^2
      -- We need to solve for b: r^2 + 2rb = a^2, so b = (a^2 - r^2)/(2r)
      -- And e = r + (a^2 - r^2)/(2r) = (2r^2 + a^2 - r^2)/(2r) = (r^2 + a^2)/(2r)
      ring_nf
      rw [factorization]
      ring
    
    -- From the above and r = e - b:
    have : (b : ℚ) = (e : ℚ) - r := by
      simp [Nat.cast_sub (Nat.le_of_lt e_gt_b)]
    rw [this, e_form]
    field_simp
    ring

  exact ⟨r, r_div_a2, r_pos, r_lt_a, param_form⟩

-- Main theorem: No perfect cuboid with prime side a
theorem no_perfect_cuboid_prime_a (p : ℕ) (hp : Nat.Prime p) :
  ¬ ∃ (pc : PerfectCuboid), pc.a = p := by
  intro ⟨pc, h_eq⟩
  
  -- From the parametrization lemma applied to equations a^2 + b^2 = e^2 and a^2 + c^2 = f^2
  have param_b := face_diagonal_parametrization p pc.b pc.e (h_eq ▸ pc.pos_a) pc.pos_b pc.pos_e (h_eq ▸ pc.eq2)
  have param_c := face_diagonal_parametrization p pc.c pc.f (h_eq ▸ pc.pos_a) pc.pos_c pc.pos_f (h_eq ▸ pc.eq3)
  
  obtain ⟨r₂, r₂_div, r₂_pos, r₂_lt, hb_param⟩ := param_b
  obtain ⟨r₃, r₃_div, r₃_pos, r₃_lt, hc_param⟩ := param_c
  
  -- For prime p, divisors of p^2 are {1, p, p^2}
  -- Since r₂, r₃ < p, we must have r₂, r₃ ∈ {1}
  have r₂_eq_1 : r₂ = 1 := by
    have r₂_in_set := (divisors_of_prime_squared p hp r₂).mpr r₂_div
    cases' Set.mem_insert_iff.mp r₂_in_set with h1 h_rest
    · exact h1
    · cases' Set.mem_insert_iff.mp h_rest with h_p h_p2
      · rw [h_p] at r₂_lt; exact absurd r₂_lt (Nat.lt_irrefl p)
      · rw [Set.mem_singleton_iff] at h_p2; rw [h_p2] at r₂_lt
        have p_le_p2 : p ≤ p^2 := Nat.le_pow_self (Nat.Prime.one_lt hp)  
        exact absurd r₂_lt (Nat.not_lt.mpr p_le_p2)
  
  have r₃_eq_1 : r₃ = 1 := by
    have r₃_in_set := (divisors_of_prime_squared p hp r₃).mpr r₃_div
    cases' Set.mem_insert_iff.mp r₃_in_set with h1 h_rest
    · exact h1  
    · cases' Set.mem_insert_iff.mp h_rest with h_p h_p2
      · rw [h_p] at r₃_lt; exact absurd r₃_lt (Nat.lt_irrefl p)
      · rw [Set.mem_singleton_iff] at h_p2; rw [h_p2] at r₃_lt
        have p_le_p2 : p ≤ p^2 := Nat.le_pow_self (Nat.Prime.one_lt hp)
        exact absurd r₃_lt (Nat.not_lt.mpr p_le_p2)
  
  -- Therefore b = c = (p^2 - 1)/2
  rw [r₂_eq_1] at hb_param
  rw [r₃_eq_1] at hc_param
  have b_eq_c : pc.b = pc.c := by
    have hb_val : (pc.b : ℚ) = (p^2 - 1 : ℚ) / 2 := by
      rw [hb_param]; unfold param_b; simp; ring
    have hc_val : (pc.c : ℚ) = (p^2 - 1 : ℚ) / 2 := by  
      rw [hc_param]; unfold param_c; simp; ring
    rw [←Nat.cast_inj (R := ℚ)] at hb_val hc_val
    linarith
  
  -- For the third face diagonal b^2 + c^2 = g^2, we need another parametrization
  -- But since b = c, we have 2b^2 = g^2, which is impossible for integer solutions
  have two_b_sq_eq_g_sq : 2 * pc.b^2 = pc.g^2 := by
    rw [←b_eq_c] at pc.eq4
    exact pc.eq4
  
  -- Show this is impossible: 2n^2 ≠ m^2 for positive integers n, m
  have impossible : ¬∃ (n m : ℕ), 0 < n ∧ 0 < m ∧ 2 * n^2 = m^2 := by
    intro ⟨n, m, hn, hm, h_eq⟩
    -- If 2n^2 = m^2, then m^2 is even, so m is even
    have m_even : Even m := by
      rw [←h_eq]
      exact Even.mul_of_left (by norm_num)
    obtain ⟨k, hk⟩ := m_even
    rw [hk] at h_eq
    -- So 2n^2 = (2k)^2 = 4k^2, thus n^2 = 2k^2
    have : 2 * n^2 = 4 * k^2 := by rw [h_eq]; ring
    have n_sq_eq : n^2 = 2 * k^2 := by linarith
    -- By the same argument, n is even
    have n_even : Even n := by
      have : Even (n^2) := by rw [n_sq_eq]; exact Even.mul_of_left (by norm_num)
      exact Nat.even_pow.mp this
    obtain ⟨j, hj⟩ := n_even  
    rw [hj] at n_sq_eq
    -- So (2j)^2 = 2k^2, thus 4j^2 = 2k^2, so 2j^2 = k^2
    have : 4 * j^2 = 2 * k^2 := by rw [n_sq_eq]; ring  
    have k_sq_eq : k^2 = 2 * j^2 := by linarith
    -- This gives an infinite descent: if (n,m) is a solution, then (j,k) is a smaller solution
    -- But we can iterate this process indefinitely, contradicting the well-ordering of ℕ
    -- For rigor, we use the fact that √2 is irrational
    have j_pos : 0 < j := by
      rw [hj] at hn; simp at hn; linarith
    have k_pos : 0 < k := by  
      rw [hk] at hm; simp at hm; linarith
    -- The relation k^2 = 2j^2 with j < n, k < m gives infinite descent
    have j_lt_n : j < n := by rw [hj]; simp; exact j_pos
    have k_lt_m : k < m := by rw [hk]; simp; exact k_pos
    -- Apply strong induction / well-ordering principle
    sorry -- This requires setting up formal infinite descent, but the idea is clear
  
  exact impossible ⟨pc.b, pc.g, pc.pos_b, pc.pos_g, two_b_sq_eq_g_sq⟩

-- Extend to any prime side
